# ==============================================================================
# LEILÃO HUB BRASIL - CONFIGURAÇÃO DE AMBIENTE (VPS / PRODUCTION)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. FRONTEND CONFIGURATION
# ------------------------------------------------------------------------------
# URL da API do backend em produção. Deve apontar para o domínio ou IP público da VPS.
# Importante: O Vite injeta esta variável no build estático do frontend.
VITE_API_URL=https://appleilao.gsntech.com.br/api/auctions

# ------------------------------------------------------------------------------
# 2. BACKEND & SERVICE CONFIGURATION
# ------------------------------------------------------------------------------
# Porta de execução do servidor Express no backend
PORT=3001

# Define o ambiente como produção para desativar logs verbosos e habilitar otimizações
NODE_ENV=production

# ------------------------------------------------------------------------------
# 3. BANCO DE DADOS (POSTGRESQL NA VPS)
# ------------------------------------------------------------------------------
# Formato da URL de conexão: postgresql://[usuario]:[senha]@[host_ou_ip]:[porta]/[nome_do_banco]
# Exemplos:
# - Se o banco rodar no mesmo Docker/VPS (rede compartilhada): postgresql://postgres:sua_senha@db:5478/leilaohub
# - Se o banco rodar na VPS exposto em porta padrão: postgresql://leilaouser:senha_forte@127.0.0.1:5432/leilaodb
DATABASE_URL=postgresql://postgres:sua_senha_segura@host_da_vps_ou_servico:5432/leilao_hub_db

# ------------------------------------------------------------------------------
# 4. WEBHOOKS DO N8N (RECEBIMENTO DE DADOS DOS SCRAPERS)
# ------------------------------------------------------------------------------
# URLs dos webhooks ativos no N8N para processamento inteligente
WEBHOOK_N8N_LEILOES_MS=https://n8n.douradosap.com.br/webhook/531322fb-763e-496c-846e-364aa8de1331
WEBHOOK_N8N_SODRE=https://n8n.douradosap.com.br/webhook/receber-sodre
WEBHOOK_N8N_SUPERBID=https://n8n.douradosap.com.br/webhook/receber-superbid
WEBHOOK_N8N_COPART=https://n8n.douradosap.com.br/webhook/receber-copart
WEBHOOK_N8N_AUTOTRAN=https://n8n.douradosap.com.br/webhook/receber-autotran
WEBHOOK_N8N_PESTANA=https://n8n.douradosap.com.br/webhook/receber-pestana
WEBHOOK_N8N_MARCA_LEILOES=https://n8n.douradosap.com.br/webhook/receber-marca-leiloes

